#!/usr/bin/env bash
# Description: Update all the things

set -Eeuo pipefail
DOTFILES="${DOTFILES:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)}"

# source helpers
source "$DOTFILES/bin/lib/common.sh"
command_name=$(basename "${BASH_SOURCE[0]}")

usage() {
  cat <<EOF
  $(fmt_key "Usage:") $(fmt_key "$command_name") $(fmt_value "[options] <command>")

  Update all the things. This script can be used to update Neovim plugins,
  update Homebrew packages, and more.

Options:
    -h, --help           Show this help message
    -v, --verbose        Show verbose output
    nvim, vim            Update Neovim plugins
    homebrew, brew       Update Homebrew packages
    dotfiles             Update dotfiles
    zsh                  Update Zsh plugins
    sdkman               Update SDKMAN and installed SDKs
    all                  Update everything
EOF
}

update_homebrew() {
  fmt_title_underline "Updating Homebrew packages"

  if ! command -v brew &>/dev/null; then
    log_warning "Homebrew is not installed. Skipping..."
    return 0
  fi

  local log_file
  log_file=$(mktemp)

  run_with_spinner "brew update > '$log_file' 2>&1 && brew upgrade >> '$log_file' 2>&1" 11 "Updating Homebrew"
  local exit_status=$?

  if [[ $exit_status -ne 0 ]] || grep -q "Error\|fatal\|Failed" "$log_file"; then
    log_error "Error occurred during update"
    [[ "$verbose" == true ]] && cat "$log_file"
    rm -f "$log_file"
    return 1
  fi

  grep -A1 "=>" "$log_file" | grep -v "^--$" || log_info "No updates found"
  rm -f "$log_file"
  echo -e
}

update_nvim_plugins() {
  fmt_title_underline "Updating Neovim plugins"

  if ! command -v nvim &>/dev/null; then
    log_warning "Neovim is not installed. Skipping..."
    return 0
  fi

  local log_file
  log_file=$(mktemp)

  run_with_spinner "nvim --headless '+Lazy! sync' +qa > '$log_file' 2>&1" 11 "Updating Neovim plugins"
  local exit_status=$?

  if [[ $exit_status -ne 0 ]] || grep -q "Error\|ERROR\|Could not\|not installed" "$log_file"; then
    log_error "Error occurred during Neovim plugin update"
    [[ "$verbose" == true ]] && cat "$log_file"
    rm -f "$log_file"
    return 1
  fi

  grep -i "updated\|installed\|removed" "$log_file" || log_info "No updates found"
  rm -f "$log_file"
  echo -e
}

update_dotfiles() {
  fmt_title_underline "Updating dotfiles"

  local current_branch
  current_branch="$(git -C "$DOTFILES" symbolic-ref --short HEAD 2>/dev/null || true)"
  if [ "$current_branch" != "main" ]; then
    log_warning "Not on main branch (current: $current_branch). Skipping dotfiles update."
    return 0
  fi

  local log_file
  log_file=$(mktemp)

  run_with_spinner "git -C '$DOTFILES' fetch --quiet origin main > '$log_file' 2>&1" 11 "Checking for dotfiles updates"

  local local_rev remote_rev
  local_rev=$(git -C "$DOTFILES" rev-parse HEAD)
  remote_rev=$(git -C "$DOTFILES" rev-parse "@{u}" 2>/dev/null || true)

  if [[ -z "$remote_rev" || "$local_rev" = "$remote_rev" ]]; then
    log_info "Dotfiles are up to date"
    rm -f "$log_file"
    return 0
  fi

  echo "Updates available:"
  git -C "$DOTFILES" --no-pager log --oneline --graph --decorate --color=always HEAD.."@{u}"

  run_with_spinner "git -C '$DOTFILES' pull --ff-only origin main > '$log_file' 2>&1" 11 "Updating dotfiles"

  if [ $? -eq 0 ]; then
    log_info "Dotfiles updated successfully"
  else
    log_error "Failed to update dotfiles"
    [[ "$verbose" == true ]] && cat "$log_file"
    rm -f "$log_file"
    return 1
  fi

  rm -f "$log_file"
}

update_zsh_plugins() {
  fmt_title_underline "Updating ZSH plugins"

  local plugin_dir="${ZPLUGDIR:-$HOME/.local/share/zsh/plugins}"

  if [[ ! -d "$plugin_dir" ]]; then
    log_warning "No ZSH plugins directory found. Skipping..."
    return 0
  fi

  local found=false
  for dir in "$plugin_dir"/*/; do
    [[ -d "$dir/.git" ]] || continue
    found=true

    local name
    name=$(basename "$dir")
    local cwd
    cwd=$(pwd)
    cd "$dir" || continue

    local before
    before=$(git rev-parse HEAD)

    run_with_spinner 'git pull --quiet --recurse-submodules 2>/dev/null' 11 "Updating $name"

    local after
    after=$(git rev-parse HEAD)
    if [[ "$before" != "$after" ]]; then
      local commit_count
      commit_count=$(git rev-list --count "$before".."$after")
      local commit_msg
      commit_msg=$(git log -1 --pretty=format:"%s")
      log_success "$name updated ($commit_count new commit(s))"
      printf "  %b→ %s%b\n" "$DIM" "$commit_msg" "$RESET"
    else
      log_info "$name already up to date"
    fi

    cd "$cwd" || true
  done

  if [[ "$found" == false ]]; then
    log_warning "No ZSH plugins installed yet. Open a new shell first."
    return 0
  fi

  echo -e
  log_success "ZSH Plugin updates completed."
}

update_sdkman() {
  fmt_title_underline "Updating SDKMAN"

  local sdkman_dir="${SDKMAN_DIR:-$HOME/.sdkman}"

  if [[ ! -s "$sdkman_dir/bin/sdkman-init.sh" ]]; then
    log_warning "SDKMAN is not installed. Skipping..."
    return 0
  fi

  local log_file
  log_file=$(mktemp)

  run_with_spinner "bash -c 'export sdkman_auto_answer=true && source \"$sdkman_dir/bin/sdkman-init.sh\" && sdk update 2>&1 && sdk upgrade 2>&1' > '$log_file' 2>&1" 11 "Updating SDKMAN"

  if grep -q "Error\|fatal\|Failed" "$log_file"; then
    log_error "Error occurred during SDKMAN update"
    [[ "$verbose" == true ]] && cat "$log_file"
    rm -f "$log_file"
    return 1
  fi

  grep -i "updated\|upgraded\|installed" "$log_file" || log_info "All SDKs are up to date"
  rm -f "$log_file"
  echo -e
}

main() {
  local subcmd=""
  local verbose=false

  if [ $# -lt 1 ]; then
    usage
    exit 0
  fi

  while [[ $# -gt 0 ]]; do
    case "$1" in
    -h | --help)
      usage
      exit 0
      ;;
    -v | --verbose)
      verbose=true
      shift
      ;;
    *)
      subcmd="$1"
      shift
      ;;
    esac
  done

  case "$subcmd" in
  nvim | vim)
    update_nvim_plugins
    ;;
  homebrew | brew)
    update_homebrew
    ;;
  dotfiles)
    update_dotfiles
    ;;
  zsh)
    update_zsh_plugins
    ;;
  sdkman)
    update_sdkman
    ;;
  all)
    update_nvim_plugins
    update_homebrew
    update_zsh_plugins
    update_sdkman
    update_dotfiles
    ;;
  *)
    log_error "Unknown $command_name command: $subcmd"
    echo -e
    usage
    exit 1
    ;;
  esac
}

main "$@"
