#!/usr/bin/env zsh

########################################################
# Navigation
########################################################

c() {
  cd $CODE_DIR/$1
}

_c() {
  _files -W $CODE_DIR -/
}

h() {
  cd $HOME/$1
}

_h() {
  _files -W $HOME -/
}

md() {
  mkdir -p $1
  cd $1
}

prepend_path() {
  [[ ! -d "$1" ]] && return
  path=( $1 $path )
}

########################################################
# Utilities
########################################################

# Copy current working directory to clipboard
cpwd() {
  pwd | sed "s|^${HOME}|~|" | tr -d '\n' | pbcopy
  echo "Copied: $(pbpaste)"
}

# File/directory size
fs() {
  if du -b /dev/null > /dev/null 2>&1; then
    local arg=-sbh
  else
    local arg=-sh
  fi
  if [[ -n "$@" ]]; then
    du ${arg} -- "$@"
  else
    du ${arg} .[^.]* *
  fi
}

# Zsh startup profiler viewer
zshrc_profiler_view() {
  local logfile="$TMPDIR/zshrc_profiler.$$.log"
  if [[ ! -f "$logfile" ]]; then
    # Find most recent profiler log
    logfile=$(ls -t $TMPDIR/zshrc_profiler.*.log 2>/dev/null | head -n1)
  fi
  if [[ -z "$logfile" || ! -f "$logfile" ]]; then
    echo "No profiler log found. Run: touch ~/.zshrc.profiler && exec zsh"
    return 1
  fi
  echo "Top 20 slowest operations:"
  awk '{print $1}' "$logfile" | sort -n | tail -20 | while read time; do
    grep "$time" "$logfile" | head -1
  done
}

########################################################
# Git Functions
########################################################

g() {
  if [[ $# > 0 ]]; then
      git $@
  else
      git s
  fi
}

# Switch to default branch (auto-detects main/master)
# Usage: gcom [-p] — pass -p to pull after switching
gcom() {
  local do_pull=0

  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: gcom [-p]"
    echo "  Switch to default branch (main/master). -p to pull after."
    return 0
  fi

  [[ "$1" == "-p" ]] && do_pull=1

  if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "Not a git repository."
    return 1
  fi

  # Check for uncommitted changes
  if ! git diff --quiet HEAD 2>/dev/null; then
    echo "You have uncommitted changes. Commit or stash them first."
    return 1
  fi

  # Fetch if remote exists
  if git remote | grep -q "^origin$"; then
    git fetch origin > /dev/null 2>&1
  fi

  # Detect default branch
  local default_branch=""
  if git remote | grep -q "^origin$"; then
    default_branch=$(git remote show origin 2>/dev/null | awk '/HEAD branch/ { print $NF }')
  fi
  if [[ -z "$default_branch" ]]; then
    if git show-ref --quiet refs/heads/main; then
      default_branch="main"
    elif git show-ref --quiet refs/heads/master; then
      default_branch="master"
    else
      echo "Could not determine default branch."
      return 1
    fi
  fi

  echo "Switching to $default_branch"
  git switch "$default_branch" || return 1

  if [[ $do_pull -eq 1 ]]; then
    echo "Pulling latest..."
    git pull || return 1
  fi
}

# Rebase current branch against default branch
# Usage: grbm
grbm() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: grbm"
    echo "  Rebase current branch against default branch (main/master)."
    return 0
  fi

  if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "Not a git repository."
    return 1
  fi

  local current_branch=$(git branch --show-current)
  if [[ -z "$current_branch" ]]; then
    echo "Could not determine current branch."
    return 1
  fi

  if ! git diff --quiet HEAD 2>/dev/null; then
    echo "You have uncommitted changes. Commit or stash them first."
    return 1
  fi

  if ! git remote | grep -q "^origin$"; then
    echo "No 'origin' remote found."
    return 1
  fi

  git fetch origin > /dev/null 2>&1

  local default_branch=""
  default_branch=$(git remote show origin 2>/dev/null | awk '/HEAD branch/ { print $NF }')
  if [[ -z "$default_branch" ]]; then
    if git show-ref --quiet refs/heads/main; then
      default_branch="main"
    elif git show-ref --quiet refs/heads/master; then
      default_branch="master"
    else
      echo "Could not determine default branch."
      return 1
    fi
  fi

  if [[ "$current_branch" == "$default_branch" ]]; then
    echo "Already on $default_branch. Nothing to rebase."
    return 0
  fi

  echo "Rebasing $current_branch against $default_branch..."
  git rebase "origin/$default_branch"
}

# Push current branch to origin with upstream tracking
# Usage: gpum
gpum() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: gpum"
    echo "  Push current branch to origin with -u (upstream tracking)."
    return 0
  fi

  if ! git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    echo "Not a git repository."
    return 1
  fi

  local current_branch=$(git branch --show-current)
  if [[ -z "$current_branch" ]]; then
    echo "Could not determine current branch."
    return 1
  fi

  if ! git remote | grep -q "^origin$"; then
    echo "No 'origin' remote found."
    return 1
  fi

  echo "Pushing $current_branch to origin..."
  git push -u origin "$current_branch"
}

# Pretty git log with graph
# Usage: gll [git log options]
gll() {
  if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: gll [git log options]"
    echo "  Pretty git log with graph, colors, author, and relative dates."
    return 0
  fi

  local fmt='%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(bold white)— %an%C(reset)%C(bold yellow)%d%C(reset)'
  git log --graph --format=format:"$fmt" --abbrev-commit "$@"
}

zfetch() {
  # Terminal colors
  TC='\e['
  Rst="${TC}0m"
  Blk="${TC}30m";
  Red="${TC}31m";
  Grn="${TC}32m";
  Yel="${TC}33m";
  Blu="${TC}34m";
  Prp="${TC}35m";
  Cyn="${TC}36m";
  Wht="${TC}37m";

  git_clone_error_msg() {
      echo -e "  ${Red}[ERROR]${Rst} git clone errored: ${Red}${1}${Rst}. ${Yel}aborting...${Rst}"
  }

  # Simplest dependency fetcher known to mankind
  if [[ $1 == "update" ]]; then
      for name in ${(@k)plugins}; do
          local cwd=$(pwd)
          local dest=$plugins[$name]
          cd $dest
          echo -e "Updating ${Yel}${name}${Rst}..."
          git pull --quiet --recurse-submodules
          cd $cwd
      done
  elif [[ $1 == "ls" ]]; then
      for name in ${(@k)plugins}; do
          echo -e "${name}: ${Yel}$plugins[$name]${Rst}"
      done
  else

    # the short name of the repo (org/repo)
    local name="$1"

    local plugin_name="${2:-"${name##*/}.plugin.zsh"}"

    # where the repo is going
    local dest="${3:-"$ZPLUGDIR"}"

    # if the dest dir ends with /, append the name to it to get the real dest dir
    if [[ $dest == */ ]]; then
        dest=$dest$name
    else
        dest=$dest/$name
    fi

    local cwd=$(pwd)
    plugins[$name]=$dest

    if [[ ! -d $dest ]]; then
        local url=https://github.com/$name.git
        local ref=$3
        echo -e "Missing plugin ${Yel}${name}${Rst}"
        echo -e "  Cloning from ${Blu}${url}${Rst}..."
        if [[ -n $ref ]]; then
            git clone --quiet $url $dest
            if [[ $? != 0 ]]; then
                git_clone_error_msg $?
                cd $cwd
                return $?
            fi

            git checkout --quiet $ref
            echo -e "  Checked out branch ${ref}"
        else
            git clone --quiet --depth 1 $url $dest
            if [[ $? != 0 ]]; then
                git_clone_error_msg $?
                cd $cwd
                return $?
            fi
            echo -e "  Checked out default branch"
        fi
    fi
    plugin="$dest/$plugin_name"
    if [ -f "$plugin" ]; then
        source "$plugin"
    fi
    cd $cwd
  fi
}

